  }
  .navbar-brand{
    color:#fe424d;
    margin-right: 0.5rem;
  }
  .navbar-nav{
    background-color: white;
  }
  @media (max-width: 400px) {
    .search-inp {
      width: 110px;
    }
  }
 </style>

