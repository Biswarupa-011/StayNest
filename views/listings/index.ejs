<%layout("/layouts/boilerplate")%>
<style>
  #filters{
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }
 .filter {
  text-align: center;
  margin-top: 1rem;
  margin-right: 2rem;
  opacity: 0.7;
  cursor: pointer;
  border-bottom: 2px solid transparent; 
  transition: 0.2s opacity, 0.2s border-color; 
}
  .filter:hover{
    opacity: 1;
    border-bottom: 2px solid #f12230 !important;
  }
  .filter p {
      margin-top: 0.3rem;
      font-size: 0.8rem;
    }

    .filter div {
      font-size: 1.5rem;
    }

    .filter i {
      color: #f12230;
      ;
    }

    .tax-info {
      display: none;
      color: #f12230;
    }

    .tax-toggle {
      border: 1px solid rgba(0, 0, 0, 0.45);
      padding: 0.8rem 1rem;
      border-radius: 1rem;
      height: 3.25rem;
      margin-top: 1rem;
      margin-left: auto;
      display: flex;
      align-items: center;
    }
</style>

  <div id="filters">
    <a href="/listings?search=Trending" class="filter" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </a>   
    <a href="/listings?search=Rooms" class="filter" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </a>
    <a href="/listings?search=Mountains" class="filter" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </a>
    <a href="/listings?search=Castles" class="filter" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-hotel"></i></div>
      <p>Castles</p>
    </a>
    <a href="/listings?search=Lake" class="filter" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-water"></i></div>
      <p>Lake</p>
    </a>
    <a href="/listings?search=Camping" class="filter" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-tent"></i></div>
      <p>Camping</p>
    </a>
    <a href="/listings?search=Amazing Views" class="filter" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-eye"></i></div>
      <p>Amazing Views</p>
    </a>
    <a href="/listings?search=Iconic Cities" class="filter" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-city"></i></div>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?search=Farms" class="filter" style="text-decoration: none; color: inherit;">
      <div><i class="fa-solid fa-home"></i></div>
      <p>Farms</p>
    </a>
  <div class="task-toggle">
    <div class="form-check-reverse form-switch">
  <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
  <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
</div>
  </div>
</div>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
 <% for(let listing of allListings) { %>
  <a href="/listings/<%= listing._id %>" class="listing-link">
    <div class="card col listing-card" >
  <img src="<%= listing.image.url%>" class="card-img-top" alt="listing_image"  style="height:20rem">
  <div class="card-img-overlay"></div>    <!-- overlay to write above the photo(card) -->
  <div class="card-body">
    <p class="card-text">
       <b><%= listing.title %> <br/></b>  
        &#8377; <%=listing.price.toLocaleString("en-IN")%> /night
        <i class="tax-info">&nbsp;&nbsp;+18% GST</i>

    </p>
  </div>
</div>    
<% } %>
</div>
</a>
<script>
  let taxSwitch =document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click",()=>{
    let taxInfo=document.getElementsByClassName("tax-info");
    for(info of taxInfo){
      if(info.style.display != "inline"){
        info.style.display = "inline";
      }else{
        info.style.display ="none";
      }
    }});
</script>
